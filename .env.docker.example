# Docker Compose environment variables
# Copy this file to .env and adjust values as needed

# JWT Secrets (IMPORTANT: Change these in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-must-be-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production-must-be-at-least-32-characters-long

# Internal API Keys
INTERNAL_API_KEY=ms1-internal-api-key-change-me-in-production

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reservations
