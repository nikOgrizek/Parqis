# Server Configuration
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reservations

# JWT Secrets (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ms1-reservations
KAFKA_GROUP_ID=reservations-group

# Redis (optional for caching)
REDIS_URL=redis://localhost:6379

# API Keys for internal communication
INTERNAL_API_KEY=ms1-internal-api-key-change-me

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
